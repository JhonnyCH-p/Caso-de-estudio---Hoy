{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "tests/test-plan-entity.ts", "tests/test-plan-repository.ts", "tests/test-plan-service.ts", "tests/test-plan-entity.ts", "tests/test-plan-repository.ts", "tests/test-plan-service.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}